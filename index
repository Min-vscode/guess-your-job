            <div class="stat-num">~60s</div>
            <div class="stat-label">To Complete</div>
          </div>
        </div>
      </div>

      <!-- QUIZ SCREEN -->

      <div id="quizScreen" class="screen">
        <div class="quiz-header">
          <div class="q-counter">Question <span id="qNum">1</span> of 5</div>
          <div
            class="q-counter"
            id="qCategory"
            style="color: var(--pink)"
          ></div>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="progressFill" style="width: 0%"></div>
        </div>
        <div class="question-text" id="questionText"></div>
        <div class="options-grid" id="optionsGrid"></div>
        <div class="quiz-footer">
          <button
            class="btn-next"
            id="nextBtn"
            onclick="nextQuestion()"
            disabled
          >
            Next →
          </button>
        </div>
      </div>

      <!-- THINKING SCREEN -->

      <div id="thinkingScreen" class="screen">
        <span class="thinking-icon">🧠</span>
        <div class="thinking-title">Analyzing your profile...</div>
        <div class="thinking-sub">
          Running pattern recognition on your answers
        </div>
        <div class="dots">
          <div class="dot"></div>
          <div class="dot"></div>
          <div class="dot"></div>
        </div>
      </div>

      <!-- RESULT SCREEN -->

      <div id="resultScreen" class="screen">
        <div class="result-eyebrow">MY PREDICTION</div>
        <div class="result-verdict">
          You're in <span class="result-field-name" id="resultField"></span>
        </div>

        ```
        <div class="accuracy-bar-wrap">
          <div class="accuracy-label">
            <span>Confidence Score</span>
            <span id="accuracyPct">—</span>
          </div>
          <div class="accuracy-track">
            <div class="accuracy-fill" id="accuracyFill"></div>
          </div>
        </div>

        <div class="result-cards">
          <div class="result-card">
            <div class="result-card-label">🧬 Personality Type</div>
            <div class="result-card-value" id="resultPersonality"></div>
          </div>
          <div class="result-card">
            <div class="result-card-label">⚡ Your Superpower</div>
            <div class="result-card-value" id="resultSuperpower"></div>
          </div>
        </div>

        <div class="result-companies">
          <div class="result-companies-label">
            🏢 Employers at this fair hiring for your field
          </div>
          <div class="company-tags" id="resultCompanies"></div>
        </div>

        <div class="result-cta">
          <button class="btn-retry" onclick="resetQuiz()">↺ Try Again</button>
          <button class="btn-share" onclick="shareResult()">
            Share Your Result 🔥
          </button>
        </div>
        ```
      </div>
    </div>

