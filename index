            { name: 'People Ops Collective', color: '#2affa0' },
            { name: 'Dilawri Group', color: '#f5e642' },
            { name: 'Enterprise Mobility', color: '#ff7c2a' },
            { name: 'Inkeros', color: '#ff2d78' },
          ],
        },
        sales: {
          name: 'Sales / Marketing',
          color: '#ff7c2a',
          emoji: '🔥',
          personality: 'The Persuader — you read the room and move people.',
          superpower: 'Turning conversations into opportunities',
          companies: [
            { name: 'Inkeros', color: '#ff7c2a' },
            { name: 'Enterprise Mobility', color: '#2affa0' },
            { name: 'AWS Canada', color: '#00f0ff' },
            { name: 'Modelcom Inc.', color: '#b06aff' },
          ],
        },
        healthcare: {
          name: 'Healthcare / Sciences',
          color: '#b06aff',
          emoji: '🧬',
          personality:
            'The Guardian — you make high-stakes decisions with care.',
          superpower: 'Precision under pressure',
          companies: [
            { name: 'SickKids Hospital', color: '#b06aff' },
            { name: 'ACIR Clinic', color: '#2affa0' },
            { name: 'Relationship Therapy', color: '#ff2d78' },
            { name: 'HOOPP', color: '#f5e642' },
          ],
        },
        engineering: {
          name: 'Engineering / Operations',
          color: '#2affa0',
          emoji: '⚙️',
          personality:
            'The Builder — you design systems that outlast everyone.',
          superpower: "Solving problems that don't exist yet",
          companies: [
            { name: '407 ETR', color: '#2affa0' },
            { name: 'ZenduIT', color: '#00f0ff' },
            { name: 'CTH Controls', color: '#f5e642' },
            { name: 'Orient Depot', color: '#ff7c2a' },
          ],
        },
      };

      let currentQ = 0;
      let scores = {
        tech: 0,
        finance: 0,
        consulting: 0,
        hr: 0,
        sales: 0,
        healthcare: 0,
        engineering: 0,
      };
      let answers = [];

      function showScreen(id) {
        document
          .querySelectorAll('.screen')
          .forEach((s) => s.classList.remove('active'));
        const el = document.getElementById(id);
        el.classList.add('active');
      }

      function startQuiz() {
        currentQ = 0;
        scores = {
          tech: 0,
          finance: 0,
          consulting: 0,
          hr: 0,
          sales: 0,
          healthcare: 0,
          engineering: 0,
        };
        answers = [];
        showScreen('quizScreen');
        renderQuestion();
      }

      function renderQuestion() {
        const q = QUESTIONS[currentQ];
        document.getElementById('qNum').textContent = currentQ + 1;
        document.getElementById('qCategory').textContent = q.category;
        document.getElementById('questionText').textContent = q.text;
        document.getElementById('progressFill').style.width =
          (currentQ / 5) * 100 + '%';

        const grid = document.getElementById('optionsGrid');
        const letters = ['A', 'B', 'C', 'D'];
        grid.innerHTML = q.options
          .map(
            (opt, i) => `
    <button class="option-btn" onclick="selectOption(${i})">
      <span class="option-letter">${letters[i]}</span>${opt.label}
    </button>
  `,
          )
          .join('');

        const nextBtn = document.getElementById('nextBtn');
        nextBtn.disabled = true;
        nextBtn.classList.remove('ready');
        nextBtn.textContent = currentQ === 4 ? 'Reveal Result ✨' : 'Next →';
      }

      function selectOption(idx) {
        document
          .querySelectorAll('.option-btn')
          .forEach((b) => b.classList.remove('selected'));
        document.querySelectorAll('.option-btn')[idx].classList.add('selected');
        answers[currentQ] = idx;

        const nextBtn = document.getElementById('nextBtn');
        nextBtn.disabled = false;
        nextBtn.classList.add('ready');
      }

      function nextQuestion() {
        const selectedIdx = answers[currentQ];
        if (selectedIdx === undefined) return;

        const fields = QUESTIONS[currentQ].options[selectedIdx].fields;
        for (const [field, val] of Object.entries(fields)) {
          scores[field] = (scores[field] || 0) + val;
        }

        currentQ++;
        if (currentQ < 5) {
          renderQuestion();
        } else {
          showThinking();
        }
      }

      function showThinking() {
        showScreen('thinkingScreen');
        setTimeout(showResult, 2200);
      }

      function showResult() {
        const topField = Object.entries(scores).sort(
          (a, b) => b[1] - a[1],
        )[0][0];
        const totalScore = Object.values(scores).reduce((a, b) => a + b, 0);
        const topScore = scores[topField];
        const confidence = Math.min(
          98,
          Math.round(55 + (topScore / totalScore) * 100),
        );

        const field = FIELDS[topField];
        showScreen('resultScreen');

        const fieldEl = document.getElementById('resultField');
        fieldEl.textContent = `${field.emoji} ${field.name}`;
        fieldEl.style.color = field.color;

        document.getElementById('resultPersonality').textContent =
          field.personality;
        document.getElementById('resultSuperpower').textContent =
          field.superpower;
        document.getElementById('accuracyPct').textContent = confidence + '%';

        const fill = document.getElementById('accuracyFill');
        fill.style.background = `linear-gradient(90deg, ${field.color}, var(--pink))`;
        setTimeout(() => {
          fill.style.width = confidence + '%';
        }, 100);

        const tagsEl = document.getElementById('resultCompanies');
        tagsEl.innerHTML = field.companies
          .map(
            (c) => `
    <span class="company-tag" style="color:${c.color}; border-color:${c.color}20; background:${c.color}10">
      ${c.name}
    </span>
  `,
          )
          .join('');

        launchConfetti(field.color);
      }

      function launchConfetti(color) {
        const colors = [color, '#f5e642', '#ff2d78', '#00f0ff', '#2affa0'];
        for (let i = 0; i < 40; i++) {
          const el = document.createElement('div');
          el.className = 'confetti-piece';
          el.style.cssText = `
      left: ${Math.random() * 100}vw;
      top: -10px;
      background: ${colors[Math.floor(Math.random() * colors.length)]};
      animation-duration: ${1.2 + Math.random() * 2}s;
      animation-delay: ${Math.random() * 0.8}s;
      width: ${6 + Math.random() * 8}px;
      height: ${6 + Math.random() * 8}px;
      border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
    `;
          document.body.appendChild(el);
          setTimeout(() => el.remove(), 4000);
        }
      }

      function resetQuiz() {
        startQuiz();
      }

      function shareResult() {
        const field = document.getElementById('resultField').textContent;
        const pct = document.getElementById('accuracyPct').textContent;
        const text = `The algorithm guessed my field: ${field} with ${pct} confidence 🎯 Try it yourself!`;
        if (navigator.share) {
          navigator.share({ title: "I'll Guess Your Job", text });
        } else {
          navigator.clipboard.writeText(text).then(() => {
            const btn = document.querySelector('.btn-share');
            btn.textContent = '✓ Copied to clipboard!';
            setTimeout(() => (btn.textContent = 'Share Your Result 🔥'), 2000);
          });
        }
      }
    </script>
  </body>
</html>
