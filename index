<!DOCTYPE html>

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>I'll Guess Your Job 🎯</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Archivo:wght@400;600&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #0a0a0f;
        --card: #12121a;
        --border: #2a2a3a;
        --yellow: #f5e642;
        --cyan: #00f0ff;
        --pink: #ff2d78;
        --orange: #ff7c2a;
        --green: #2affa0;
        --purple: #b06aff;
        --white: #f0f0ff;
        --muted: #6a6a88;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: var(–bg);
        color: var(–white);
        font-family: ‘Archivo’, sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
      }

      /* Animated grid background */
      body::before {
        content: ‘’;
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(0, 240, 255, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0, 240, 255, 0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        animation: gridMove 20s linear infinite;
        pointer-events: none;
      }

      body::after {
        content: ‘’;
        position: fixed;
        inset: 0;
        background: radial-gradient(
          ellipse 80% 60% at 50% 50%,
          rgba(176, 106, 255, 0.06) 0%,
          transparent 70%
        );
        pointer-events: none;
      }

      @keyframes gridMove {
        0% {
          transform: translateY(0);
        }
        100% {
          transform: translateY(40px);
        }
      }

      .container {
        width: 100%;
        max-width: 680px;
        padding: 24px;
        position: relative;
        z-index: 10;
      }

      /* SCREEN MANAGEMENT */
      .screen {
        display: none;
        animation: fadeUp 0.4s ease forwards;
      }
      .screen.active {
        display: block;
      }

      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(24px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* –– INTRO SCREEN –– */
      .intro-badge {
        display: inline-block;
        background: var(–yellow);
        color: #0a0a0f;
        font-family:
          ‘Space Mono’,
          monospace;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        padding: 6px 14px;
        border-radius: 2px;
        margin-bottom: 24px;
        text-transform: uppercase;
      }

      .intro-title {
        font-family:
          ‘Archivo Black’,
          sans-serif;
        font-size: clamp(48px, 9vw, 80px);
        line-height: 0.95;
        letter-spacing: -2px;
        margin-bottom: 8px;
      }

      .intro-title .line1 {
        color: var(–white);
        display: block;
      }
      .intro-title .line2 {
        display: block;
        background: linear-gradient(90deg, var(–cyan), var(–pink));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .intro-subtitle {
        color: var(–muted);
        font-size: 15px;
        margin: 20px 0 36px;
        line-height: 1.6;
        max-width: 440px;
      }

      .intro-subtitle strong {
        color: var(–cyan);
        font-weight: 600;
      }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(–yellow);
        color: #0a0a0f;
        font-family:
          ‘Archivo Black’,
          sans-serif;
        font-size: 16px;
        letter-spacing: 0.5px;
        padding: 18px 36px;
        border: none;
        cursor: pointer;
        border-radius: 4px;
        transition:
          transform 0.15s,
          box-shadow 0.15s;
        text-transform: uppercase;
      }

      .btn-primary:hover {
        transform: translate(-3px, -3px);
        box-shadow: 6px 6px 0 var(–pink);
      }
      .btn-primary:active {
        transform: translate(0, 0);
        box-shadow: none;
      }

      .intro-stats {
        display: flex;
        gap: 32px;
        margin-top: 48px;
        padding-top: 32px;
        border-top: 1px solid var(–border);
      }

      .stat-item {
        text-align: left;
      }
      .stat-num {
        font-family:
          ‘Space Mono’,
          monospace;
        font-size: 28px;
        font-weight: 700;
        color: var(–cyan);
      }
      .stat-label {
        font-size: 12px;
        color: var(–muted);
        margin-top: 2px;
        letter-spacing: 0.5px;
      }

      /* –– QUIZ SCREEN –– */
      .quiz-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 32px;
      }

      .q-counter {
        font-family:
          ‘Space Mono’,
          monospace;
        font-size: 13px;
        color: var(–muted);
      }
      .q-counter span {
        color: var(–yellow);
        font-weight: 700;
      }

      .progress-bar {
        height: 3px;
        background: var(–border);
        border-radius: 2px;
        margin-bottom: 40px;
        overflow: hidden;
      }

      .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(–cyan), var(–pink));
        border-radius: 2px;
        transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .question-text {
        font-family:
          ‘Archivo Black’,
          sans-serif;
        font-size: clamp(22px, 4vw, 32px);
        line-height: 1.2;
        margin-bottom: 32px;
        letter-spacing: -0.5px;
      }

      .options-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      .option-btn {
        background: var(–card);
        border: 1.5px solid var(–border);
        color: var(–white);
        font-family: ‘Archivo’, sans-serif;
        font-size: 14px;
        font-weight: 600;
        padding: 18px 16px;
        cursor: pointer;
        border-radius: 6px;
        text-align: left;
        transition: all 0.15s;
        line-height: 1.4;
        position: relative;
        overflow: hidden;
      }

      .option-btn::before {
        content: ‘’;
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.2s;
      }

      .option-btn:hover {
        border-color: var(–cyan);
        color: var(–cyan);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 240, 255, 0.12);
      }

      .option-btn.selected {
        border-color: var(–yellow);
        background: rgba(245, 230, 66, 0.08);
        color: var(–yellow);
      }

      .option-letter {
        display: inline-block;
        font-family:
          ‘Space Mono’,
          monospace;
        font-size: 11px;
        background: var(–border);
        color: var(–muted);
        padding: 2px 6px;
        border-radius: 2px;
        margin-right: 8px;
        transition: all 0.15s;
      }
      .option-btn:hover .option-letter,
      .option-btn.selected .option-letter {
        background: var(–yellow);
        color: #0a0a0f;
      }

      .quiz-footer {
        margin-top: 32px;
        display: flex;
        justify-content: flex-end;
      }

      .btn-next {
        background: transparent;
        border: 1.5px solid var(–border);
        color: var(–muted);
        font-family:
          ‘Archivo Black’,
          sans-serif;
        font-size: 13px;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 14px 28px;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s;
      }

      .btn-next.ready {
        border-color: var(–green);
        color: var(–green);
        box-shadow: 0 0 20px rgba(42, 255, 160, 0.15);
      }

      .btn-next.ready:hover {
        background: var(–green);
        color: #0a0a0f;
        transform: translate(-2px, -2px);
        box-shadow: 4px 4px 0 rgba(42, 255, 160, 0.4);
      }

      /* –– THINKING SCREEN –– */
      #thinkingScreen {
        text-align: center;
        padding: 60px 20px;
      }

      .thinking-icon {
        font-size: 64px;
        display: block;
        margin-bottom: 24px;
        animation: bounce 0.6s ease infinite alternate;
      }

      @keyframes bounce {
        from {
          transform: translateY(0);
        }
        to {
          transform: translateY(-12px);
        }
      }

      .thinking-title {
        font-family:
          ‘Archivo Black’,
          sans-serif;
        font-size: 28px;
        margin-bottom: 12px;
      }

      .thinking-sub {
        color: var(–muted);
        font-size: 14px;
      }

      .dots {
        display: inline-flex;
        gap: 8px;
        margin-top: 32px;
      }

      .dot {
        width: 10px;
        height: 10px;
        background: var(–cyan);
        border-radius: 50%;
        animation: dotPulse 1.2s ease infinite;
      }
      .dot:nth-child(2) {
        animation-delay: 0.2s;
        background: var(–pink);
      }
      .dot:nth-child(3) {
        animation-delay: 0.4s;
        background: var(–yellow);
      }

      @keyframes dotPulse {
        0%,
        60%,
        100% {
          transform: scale(1);
          opacity: 0.4;
        }
        30% {
          transform: scale(1.5);
          opacity: 1;
        }
      }

      /* –– RESULT SCREEN –– */
      .result-eyebrow {
        font-family:
          ‘Space Mono’,
          monospace;
        font-size: 11px;
        color: var(–muted);
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 12px;
      }

      .result-verdict {
        font-family:
          ‘Archivo Black’,
          sans-serif;
        font-size: clamp(36px, 7vw, 60px);
        line-height: 1;
        letter-spacing: -1.5px;
        margin-bottom: 4px;
      }

      .result-field-name {
        display: inline-block;
        padding: 4px 0;
      }

      .result-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin: 28px 0;
      }

      .result-card {
        background: var(–card);
        border: 1.5px solid var(–border);
        border-radius: 8px;
        padding: 20px;
      }

      .result-card-label {
        font-family:
          ‘Space Mono’,
          monospace;
        font-size: 10px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(–muted);
        margin-bottom: 10px;
      }

      .result-card-value {
        font-family:
          ‘Archivo Black’,
          sans-serif;
        font-size: 15px;
        line-height: 1.3;
      }

      .result-companies {
        background: var(–card);
        border: 1.5px solid var(–border);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 28px;
      }

      .result-companies-label {
        font-family:
          ‘Space Mono’,
          monospace;
        font-size: 10px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(–muted);
        margin-bottom: 14px;
      }

      .company-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .company-tag {
        font-size: 12px;
        font-weight: 600;
        padding: 6px 12px;
        border-radius: 3px;
        border: 1.5px solid;
      }

      .result-cta {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .btn-retry {
        flex: 1;
        background: transparent;
        border: 1.5px solid var(–border);
        color: var(–muted);
        font-family:
          ‘Archivo Black’,
          sans-serif;
        font-size: 13px;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 16px 24px;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s;
      }

      .btn-retry:hover {
        border-color: var(–white);
        color: var(–white);
      }

      .btn-share {
        flex: 2;
        background: var(–pink);
        border: none;
        color: var(–white);
        font-family:
          ‘Archivo Black’,
          sans-serif;
        font-size: 13px;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 16px 24px;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.2s;
      }

      .btn-share:hover {
        transform: translate(-2px, -2px);
        box-shadow: 4px 4px 0 rgba(255, 45, 120, 0.35);
      }

      /* Accuracy meter */
      .accuracy-bar-wrap {
        margin: 20px 0 24px;
      }
      .accuracy-label {
        display: flex;
        justify-content: space-between;
        font-family:
          ‘Space Mono’,
          monospace;
        font-size: 11px;
        color: var(–muted);
        margin-bottom: 6px;
      }
      .accuracy-track {
        height: 6px;
        background: var(–border);
        border-radius: 3px;
        overflow: hidden;
      }
      .accuracy-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1) 0.3s;
        width: 0%;
      }

      /* Confetti */
      .confetti-piece {
        position: fixed;
        width: 8px;
        height: 8px;
        border-radius: 2px;
        pointer-events: none;
        z-index: 999;
        animation: confettiFall linear forwards;
      }

      @keyframes confettiFall {
        0% {
          transform: translateY(-20px) rotate(0deg);
          opacity: 1;
        }
        100% {
          transform: translateY(100vh) rotate(720deg);
          opacity: 0;
        }
      }

      @media (max-width: 480px) {
        .options-grid {
          grid-template-columns: 1fr;
        }
        .result-cards {
          grid-template-columns: 1fr;
        }
        .intro-stats {
          gap: 20px;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <!-- INTRO SCREEN -->

      <div id="introScreen" class="screen active">
        <div class="intro-badge">🎯 Career Fair Edition</div>
        <h1 class="intro-title">
          <span class="line1">I'LL GUESS</span>
          <span class="line2">YOUR JOB.</span>
        </h1>
        <p class="intro-subtitle">
          Answer <strong>5 quick questions</strong> and I'll predict your field
          & personality type using data pattern matching. Built by a
          <strong>Business & Data Analyst</strong> — let's see if the model is
          right.
        </p>
        <button class="btn-primary" onclick="startQuiz()">Let's go ⚡</button>
        <div class="intro-stats">
          <div class="stat-item">
            <div class="stat-num">5</div>
            <div class="stat-label">Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-num">7</div>
            <div class="stat-label">Fields Detected</div>
          </div>
